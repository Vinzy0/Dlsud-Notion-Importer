{
    "manifest_version": 3,
    "name": "UDScraper",
    "version": "2.0",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "downloads",
        "offscreen",
        "identity",
        "alarms"
    ],
    "host_permissions": [
        "https://dlsud.edu20.org/*",
        "https://api.notion.com/*",
        "https://*.workers.dev/*"
    ],
    "icons": {
        "16":  "icons/icon16.png",
        "48":  "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16":  "icons/icon16.png",
            "48":  "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    }
}