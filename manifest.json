{
    "manifest_version": 3,
    "name": "DLSUD to Notion",
    "version": "1.1",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "https://dlsud.edu20.org/*",
        "https://api.notion.com/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    }
}