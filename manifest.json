{
    "manifest_version": 3,
    "name": "DLSUD to Notion",
    "version": "2.0",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "downloads"
    ],
    "host_permissions": [
        "https://dlsud.edu20.org/*",
        "https://api.notion.com/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    }
}